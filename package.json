{
  "name": "goxt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "check": "tsc --noEmit",
    "test": "bun test",
    "validate": "bun run check && bun test",
    "protocol:verify": "bun scripts/protocol-snapshot.ts verify",
    "protocol:generate": "bun scripts/protocol-snapshot.ts generate"
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "effect": "4.0.0-beta.98",
    "opentui-spinner": "0.0.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
